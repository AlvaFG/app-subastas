# URL del backend que consume la app (web y mobile).
#
# - 'auto' o sin setear: autodetecta el host del bundler de Expo (solo dev local).
# - Produccion: la URL HTTPS del backend en la VM de Azure, con sufijo /api.
#   El cliente de Socket.IO deriva su URL quitando el /api automaticamente.
EXPO_PUBLIC_API_URL=https://subastas-api-fvasquez.canadacentral.cloudapp.azure.com/api
