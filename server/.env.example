PORT=3000
DB_USER=sa
DB_PASSWORD=
DB_SERVER=localhost
DB_NAME=subastas
DB_PORT=1433
JWT_SECRET=
JWT_REFRESH_SECRET=

# Rate limit de /api/auth: requests por IP cada 15 min. 0 = desactivado. Default 200.
AUTH_RATE_LIMIT_MAX=200
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# URL publica del front web (para armar el link de recupero de clave).
# Si se omite, se usa el primer origen de CORS_ORIGINS.
WEB_URL=

# SMTP para enviar el mail de recupero de clave (forgot-password).
# Si no se configura, el endpoint sigue respondiendo OK pero no envia el mail
# (se loguea un warning). Ej. para Gmail: host smtp.gmail.com, port 587, una App Password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
